# Neo4j Aura (既存DB)
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# Z.ai (GLM-4.7)
ZAI_API_KEY=your_zai_key

# Flask session secret (本番では必ず固定値にする)
SECRET_KEY=change_me_to_a_long_random_string

# パフォーマンス調整（任意）
LLM_TIMEOUT=120
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=4
RETRIEVER_K=3

# Renderが自動でPORTを渡します（ローカル用のデフォルト）
PORT=5000

